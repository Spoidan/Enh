// This is your Prisma schema file
// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Users ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         String   @default("assistant") // admin | assistant
  passwordHash String?
  isSetup      Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─── School Settings ─────────────────────────────────────────────────────────

model SchoolSettings {
  id           String   @id @default(cuid())
  schoolName   String   @default("")
  address      String?
  phone        String?
  email        String?
  directorName String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("school_settings")
}

// ─── Academic Year ────────────────────────────────────────────────────────────

model SchoolYear {
  id                String               @id @default(cuid())
  name              String
  startDate         DateTime
  endDate           DateTime
  isActive          Boolean              @default(false)
  isArchived        Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  terms             Term[]
  yearFeeStructures YearFeeStructure[]
  enrollments       StudentEnrollment[]

  @@map("school_years")
}

model Term {
  id           String     @id @default(cuid())
  schoolYearId String
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  name         String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("terms")
}

// ─── Core School Models ───────────────────────────────────────────────────────

model Class {
  id                String               @id @default(cuid())
  name              String
  section           String?
  gradeLevel        String?
  capacity          Int?
  students          Student[]
  feeStructures     FeeStructure[]
  yearFeeStructures YearFeeStructure[]
  enrollments       StudentEnrollment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@map("classes")
}

model Student {
  id          String               @id @default(cuid())
  name        String
  rollNumber  String               @unique
  classId     String
  class       Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  parentName  String?
  parentPhone String?
  parentEmail String?
  photoUrl    String?
  address     String?
  dateOfBirth DateTime?
  gender      String?
  isActive    Boolean              @default(true)
  payments    Payment[]
  sales       Sale[]
  extraFees   ExtraFee[]
  discounts   Discount[]
  enrollments StudentEnrollment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("students")
}

model StudentEnrollment {
  id             String     @id @default(cuid())
  studentId      String
  schoolYearId   String
  classId        String
  enrollmentDate DateTime   @default(now())
  status         String     @default("active") // active | inactive
  inactiveReason String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  class      Class      @relation(fields: [classId], references: [id])

  @@unique([studentId, schoolYearId])
  @@map("student_enrollments")
}

model ExtraFee {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  trimester   Int?     // 1, 2, or 3 — null means applies to all
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("extra_fees")
}

model Discount {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  trimester   Int?     // 1, 2, or 3 — null means applies to all
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("discounts")
}

model FeeStructure {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  name        String
  amount      Float
  period      String   @default("monthly")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fee_structures")
}

model YearFeeStructure {
  id                String     @id @default(cuid())
  schoolYearId      String
  schoolYear        SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)
  classId           String
  class             Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  amount            Float      // Total (used for annual_t1 or fallback)
  description       String?
  paymentFrequency  String     @default("annual_t1") // annual_t1 | per_trimester | specific_trimester
  amountT1          Float?
  amountT2          Float?
  amountT3          Float?
  specificTrimester Int?       // 1, 2, or 3 — used with specific_trimester
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([schoolYearId, classId])
  @@map("year_fee_structures")
}

model Payment {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Float
  date      DateTime
  method    String   @default("cash")
  reference String?
  notes     String?
  month     Int?
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  type        String // uniform | book | other
  price       Float
  stock       Int      @default(0)
  description String?
  sku         String?
  sales       Sale[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inventory_items")
}

model Sale {
  id        String        @id @default(cuid())
  studentId String?
  student   Student?      @relation(fields: [studentId], references: [id])
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  quantity  Int
  unitPrice Float
  amount    Float
  date      DateTime
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("sales")
}

model Deposit {
  id        String   @id @default(cuid())
  date      DateTime
  amount    Float
  source    String
  bankName  String?
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("deposits")
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Float
  category    String
  description String?
  payee       String?
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}

// ─── HR / Salary ──────────────────────────────────────────────────────────────

model StaffMember {
  id            String          @id @default(cuid())
  name          String
  role          String? // e.g., Enseignant, Directeur, Administratif
  monthlySalary Float
  isActive      Boolean         @default(true)
  payments      SalaryPayment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("staff_members")
}

model SalaryPayment {
  id        String      @id @default(cuid())
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  amount    Float
  month     Int
  year      Int
  date      DateTime
  status    String      @default("payé") // payé | en attente
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("salary_payments")
}

model SalaryDebitLetter {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  fileUrl   String
  fileName  String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("salary_debit_letters")
}

// ─── INSS & Mutuelle ─────────────────────────────────────────────────────────

model INSSPayment {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  amount    Float
  date      DateTime
  status    String   @default("payé")
  fileUrl   String?
  fileName  String?
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inss_payments")
}

model MutuellePayment {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  amount    Float
  date      DateTime
  status    String   @default("payé")
  fileUrl   String?
  fileName  String?
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mutuelle_payments")
}
